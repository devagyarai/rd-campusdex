// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================
enum VisibilityLevel {
  PUBLIC
  PRIVATE
  PROTECTED
}

enum FileState {
  UPLOADING
  ACTIVE
  FAILED
  DELETED
}

// ============================================================
// USERS
// ============================================================

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String
  role           String      @default("STUDENT")
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
  lastPasswordReset    DateTime?
  sessionVersion       Int       @default(0)

  storageQuota   Int       @default(1073741824) // 1GB
  storageUsed    Int       @default(0)

  student              Student?
  admin                Admin?
  notifications        Notification[]
  cloudFiles           CloudFile[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ============================================================
// CLOUD FILES
// ============================================================

model CloudFile {
  id           String   @id @default(cuid())
  publicId     String   @unique
  url          String
  secureUrl    String
  format       String
  bytes        Int
  resourceType String   @default("auto")
  originalName String

  fileHash     String?
  state        FileState @default(UPLOADING)
  visibility   VisibilityLevel @default(PRIVATE)

  isScanned    Boolean  @default(false)
  isSafe       Boolean  @default(false)
  scanProvider String?
  scanResult   String?

  uploadedById String
  ownerType    String?
  ownerId      String?

  accessCount    Int       @default(0)
  downloadCount  Int       @default(0)
  lastAccessedAt DateTime?

  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  
  studentProfiles Student[] @relation("StudentProfileImage")
  adminProfiles Admin[]     @relation("AdminProfileImage")
  notices Notice[]          @relation("NoticeAttachment")
  assignments Assignment[]  @relation("AssignmentAttachment")
  assignmentSubmissions AssignmentSubmission[] @relation("SubmissionFile")
  
  noteId       String?
  note         Note?     @relation(fields: [noteId], references: [id], onDelete: SetNull)

  @@index([uploadedById])
  @@index([publicId])
  @@index([state])
  @@map("cloud_files")
}

// ============================================================
// PROFILES
// ============================================================

model Student {
  id             String    @id @default(cuid())
  userId         String    @unique
  firstName      String
  lastName       String
  rollNumber     String    @unique
  phone          String?
  dateOfBirth    DateTime?
  gender         String?
  address        String?   
  
  profileImageId String?
  profileImage   CloudFile? @relation("StudentProfileImage", fields: [profileImageId], references: [id], onDelete: SetNull)
  // Legacy field
  legacyProfileImage String?

  department     String
  semester       Int       @default(1)
  batch          String
  enrollmentDate DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendances         Attendance[]
  assignmentSubmissions AssignmentSubmission[]
  notes               Note[]

  @@index([userId])
  @@index([rollNumber])
  @@index([department])
  @@map("students")
}

model Admin {
  id           String   @id @default(cuid())
  userId       String   @unique
  firstName    String
  lastName     String
  employeeId   String   @unique
  phone        String?
  designation  String
  department   String
  
  profileImageId String?
  profileImage   CloudFile? @relation("AdminProfileImage", fields: [profileImageId], references: [id], onDelete: SetNull)
  // Legacy
  legacyProfileImage String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notices  Notice[]
  assignments Assignment[]

  @@index([userId])
  @@map("admins")
}

// ============================================================
// ACADEMIC
// ============================================================

model Subject {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?  
  credits     Int      @default(3)
  department  String
  semester    Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attendances  Attendance[]
  timetables   Timetable[]
  assignments  Assignment[]

  @@index([code])
  @@index([department])
  @@map("subjects")
}

model Timetable {
  id        String   @id @default(cuid())
  subjectId String
  day String
  startTime String
  endTime   String
  room      String
  semester  Int
  batch     String
  department String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
  @@index([day])
  @@index([semester])
  @@map("timetables")
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  subjectId String
  date      DateTime         
  status String @default("PRESENT")
  remarks   String?
  markedBy  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, date])
  @@index([studentId])
  @@index([subjectId])
  @@index([date])
  @@map("attendances")
}

// ============================================================
// ASSIGNMENTS
// ============================================================

model Assignment {
  id           String             @id @default(cuid())
  title        String
  description  String             
  subjectId    String
  adminId      String
  dueDate      DateTime
  totalMarks   Int                @default(100)
  priority     String @default("MEDIUM")
  
  attachmentId String?
  attachment   CloudFile? @relation("AssignmentAttachment", fields: [attachmentId], references: [id], onDelete: SetNull)
  attachmentUrl String? // Legacy

  isPublished  Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  subject     Subject               @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  admin       Admin                 @relation(fields: [adminId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@index([subjectId])
  @@index([adminId])
  @@index([dueDate])
  @@map("assignments")
}

model AssignmentSubmission {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  status String @default("PENDING")
  submittedAt  DateTime?
  
  fileId       String?
  file         CloudFile? @relation("SubmissionFile", fields: [fileId], references: [id], onDelete: SetNull)
  fileUrl      String? // Legacy
  
  remarks      String?          
  marksObtained Int?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@map("assignment_submissions")
}

// ============================================================
// NOTICES
// ============================================================

model Notice {
  id          String         @id @default(cuid())
  title       String
  content     String         
  category    String         @default("GENERAL")
  adminId     String
  isPinned    Boolean        @default(false)
  isPublished Boolean        @default(true)
  
  attachmentId String?
  attachment   CloudFile? @relation("NoticeAttachment", fields: [attachmentId], references: [id], onDelete: SetNull)
  attachmentUrl String? // Legacy
  
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([category])
  @@index([isPinned])
  @@map("notices")
}

// ============================================================
// NOTES
// ============================================================

model Note {
  id        String       @id @default(cuid())
  title     String
  content   String       
  category String @default("LECTURE")
  studentId String
  tags      String?
  isPinned  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  files   CloudFile[] 

  @@index([studentId])
  @@index([category])
  @@map("notes")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// ============================================================
// SECURITY AUDIT LOGS
// ============================================================

model SecurityAuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  userId    String?
  email     String?
  ipAddress String?
  userAgent String?
  action    String   

  @@index([email, action, timestamp])
  @@index([ipAddress, action, timestamp])
  @@map("security_audit_logs")
}
